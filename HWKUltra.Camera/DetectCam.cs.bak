using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace WD.AVI.BaslerCam
{
    public class DetectCam : AVICamera
    {
        private static DetectCam uniqueInstance;
        private static readonly object locker = new object();

        private DetectCam(string detectCamSN) : base(detectCamSN)
        {

        }

        public static DetectCam GetInstance(string camSN)
        {
            if (uniqueInstance == null)
            {
                lock (locker)
                {
                    if (uniqueInstance == null)
                    {
                        uniqueInstance = new DetectCam(camSN);
                    }
                }
            }
            return uniqueInstance;
        }
    }

}
