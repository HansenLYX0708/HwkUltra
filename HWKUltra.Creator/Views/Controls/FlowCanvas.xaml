<UserControl x:Class="HWKUltra.Creator.Views.Controls.FlowCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:HWKUltra.Creator.Converters"
             xmlns:vm="clr-namespace:HWKUltra.Creator.ViewModels"
             AllowDrop="True"
             Drop="Canvas_Drop"
             DragOver="Canvas_DragOver"
             Background="Transparent"
             ClipToBounds="True"
             Focusable="True"
             KeyDown="Canvas_KeyDown"
             MouseDown="Canvas_MouseDown">

    <UserControl.Resources>
        <converters:StringToBrushConverter x:Key="StringToBrush" />
        <converters:StringToSemiTransparentBrushConverter x:Key="StringToSemiTransparentBrush" />
        <converters:BoolToHighlightBrushConverter x:Key="BoolToHighlightBrush" />
        <converters:BoolToThicknessConverter x:Key="BoolToThickness" />
        <converters:ConnectionPathConverter x:Key="ConnectionPathConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </UserControl.Resources>

    <Grid>
        <!-- Canvas with pan/zoom transform -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      x:Name="CanvasScrollViewer">
            <Grid x:Name="CanvasRoot" Width="4000" Height="3000"
                  MouseWheel="CanvasRoot_MouseWheel">

                <!-- Grid Background -->
                <Grid.Background>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing>
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <EllipseGeometry Center="0,0" RadiusX="0.5" RadiusY="0.5" />
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                                <GeometryDrawing.Brush>
                                    <SolidColorBrush Color="#33888888" />
                                </GeometryDrawing.Brush>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Grid.Background>

                <!-- Connection Lines Layer (below nodes) -->
                <ItemsControl ItemsSource="{Binding Connections}" x:Name="ConnectionsLayer">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FlowConnectionViewModel}">
                            <Canvas>
                                <!-- Bezier connection line -->
                                <Path StrokeThickness="2" x:Name="ConnectionPath"
                                      MouseDown="Connection_MouseDown"
                                      Cursor="Hand"
                                      Stroke="{Binding IsSelected, Converter={StaticResource BoolToHighlightBrush}}"
                                      Tag="{Binding}">
                                    <Path.Data>
                                        <MultiBinding Converter="{StaticResource ConnectionPathConverter}">
                                            <Binding Path="SourceX" />
                                            <Binding Path="SourceY" />
                                            <Binding Path="TargetX" />
                                            <Binding Path="TargetY" />
                                        </MultiBinding>
                                    </Path.Data>
                                </Path>
                                <!-- Wider invisible hit-test path -->
                                <Path StrokeThickness="12" Stroke="Transparent"
                                      MouseDown="Connection_MouseDown"
                                      Cursor="Hand"
                                      Tag="{Binding}">
                                    <Path.Data>
                                        <MultiBinding Converter="{StaticResource ConnectionPathConverter}">
                                            <Binding Path="SourceX" />
                                            <Binding Path="SourceY" />
                                            <Binding Path="TargetX" />
                                            <Binding Path="TargetY" />
                                        </MultiBinding>
                                    </Path.Data>
                                </Path>
                                <!-- Condition label at midpoint -->
                                <TextBlock Text="{Binding Condition}"
                                           Visibility="{Binding Condition, Converter={StaticResource NullToVisibility}}"
                                           FontSize="10" Foreground="#AAFFFFFF"
                                           Background="#88000000" Padding="3,1">
                                    <Canvas.Left>
                                        <Binding Path="MidX" />
                                    </Canvas.Left>
                                    <Canvas.Top>
                                        <Binding Path="MidY" />
                                    </Canvas.Top>
                                </TextBlock>
                            </Canvas>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Temporary connection line (when dragging to create a new connection) -->
                <Canvas x:Name="TempConnectionLayer">
                    <Path x:Name="TempConnectionPath" Stroke="#8800AAFF" StrokeThickness="2"
                          StrokeDashArray="4 2" Visibility="Collapsed" />
                </Canvas>

                <!-- Node Items Layer -->
                <ItemsControl ItemsSource="{Binding Nodes}" x:Name="NodesLayer">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FlowNodeViewModel}">
                            <!-- Node Visual -->
                            <Border x:Name="NodeBorder"
                                    Width="{Binding Width}" MinHeight="{Binding Height}"
                                    CornerRadius="6"
                                    Background="{Binding Color, Converter={StaticResource StringToSemiTransparentBrush}}"
                                    BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToHighlightBrush}}"
                                    BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToThickness}}"
                                    Cursor="SizeAll"
                                    MouseDown="Node_MouseDown"
                                    MouseMove="Node_MouseMove"
                                    MouseUp="Node_MouseUp"
                                    Tag="{Binding}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Start node indicator -->
                                    <Border Grid.Row="0" CornerRadius="6,6,0,0" Padding="0"
                                            Visibility="{Binding IsStartNode, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="▶ START" FontSize="9" Foreground="#4CAF50"
                                                   HorizontalAlignment="Center" Margin="0,2" />
                                    </Border>

                                    <!-- Title bar with color accent -->
                                    <Border Grid.Row="1" CornerRadius="6,6,0,0" Padding="8,5"
                                            Background="{Binding Color, Converter={StaticResource StringToBrush}}">
                                        <Grid>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="White" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding NodeType}" />
                                        </Grid>
                                    </Border>

                                    <!-- Body: type label + ports hint -->
                                    <StackPanel Grid.Row="2" Margin="8,4,8,6">
                                        <TextBlock Text="{Binding NodeType}" FontSize="10" Opacity="0.6"
                                                   Margin="0,0,0,2" />
                                        <TextBlock Text="{Binding Description}" FontSize="10" Opacity="0.5"
                                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                   MaxHeight="30" />
                                    </StackPanel>

                                    <!-- Output Port (right side) -->
                                    <Ellipse Grid.Row="1" Width="12" Height="12"
                                             Fill="#4CAF50" Stroke="White" StrokeThickness="1.5"
                                             HorizontalAlignment="Right" VerticalAlignment="Center"
                                             Margin="0,0,-6,0" Cursor="Cross"
                                             MouseDown="OutputPort_MouseDown"
                                             Tag="{Binding}" />

                                    <!-- Input Port (left side) -->
                                    <Ellipse Grid.Row="1" Width="12" Height="12"
                                             Fill="#2196F3" Stroke="White" StrokeThickness="1.5"
                                             HorizontalAlignment="Left" VerticalAlignment="Center"
                                             Margin="-6,0,0,0" Cursor="Cross"
                                             Tag="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
