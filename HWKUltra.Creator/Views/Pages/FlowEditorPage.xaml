<UserControl x:Class="HWKUltra.Creator.Views.Pages.FlowEditorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:HWKUltra.Creator.Views.Controls"
             xmlns:converters="clr-namespace:HWKUltra.Creator.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="180" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="280" MinWidth="200" />
        </Grid.ColumnDefinitions>

        <!-- Left: Node Toolbox -->
        <controls:NodeToolbox Grid.Column="0" DataContext="{Binding Toolbox}" />

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

        <!-- Center: Flow Canvas -->
        <controls:FlowCanvas Grid.Column="2" 
                             x:Name="FlowCanvasControl"
                             DataContext="{Binding Canvas}" />

        <!-- Splitter -->
        <GridSplitter Grid.Column="3" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

        <!-- Right: Property Panel -->
        <controls:PropertyPanel Grid.Column="4" DataContext="{Binding PropertyPanel}" />
    </Grid>
</UserControl>
