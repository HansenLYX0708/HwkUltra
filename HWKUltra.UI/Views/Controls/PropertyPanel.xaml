<UserControl x:Class="HWKUltra.UI.Views.Controls.PropertyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:HWKUltra.UI.Helpers"
             xmlns:vm="clr-namespace:HWKUltra.UI.ViewModels.Pages">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <converters:StringToBrushConverter x:Key="StringToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Properties" FontWeight="SemiBold" FontSize="14"
                   Margin="12,8,12,4" />

        <!-- No Selection -->
        <TextBlock Grid.Row="1" Text="Select a node or connection to edit properties"
                   Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVisibility}}"
                   Opacity="0.4" FontSize="12" Margin="12,20" TextWrapping="Wrap"
                   HorizontalAlignment="Center" TextAlignment="Center" />

        <!-- Node Properties -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsNodeSelected, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Margin="8,4">
                <!-- Node Info Header -->
                <Border Padding="8" Margin="0,0,0,8" CornerRadius="6"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="0,0,6,0"
                                       Fill="{Binding SelectedNode.Color, Converter={StaticResource StringToBrush}}" />
                            <TextBlock Text="{Binding SelectedNode.NodeType}" FontWeight="Bold" FontSize="13" />
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedNode.Category}" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </Border>

                <!-- Basic Properties -->
                <TextBlock Text="Basic" FontWeight="SemiBold" FontSize="12" Margin="4,4,0,4" />

                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="Name" FontSize="11" Opacity="0.7" Margin="4,0,0,2" />
                    <ui:TextBox Text="{Binding SelectedNode.Name, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="Description" FontSize="11" Opacity="0.7" Margin="4,0,0,2" />
                    <ui:TextBox Text="{Binding SelectedNode.Description, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True" MinHeight="40" />
                </StackPanel>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="X" FontSize="11" Opacity="0.7" Margin="4,0,0,2" />
                        <ui:TextBox Text="{Binding SelectedNode.X, UpdateSourceTrigger=LostFocus, StringFormat=F1}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Y" FontSize="11" Opacity="0.7" Margin="4,0,0,2" />
                        <ui:TextBox Text="{Binding SelectedNode.Y, UpdateSourceTrigger=LostFocus, StringFormat=F1}" />
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="ID" FontSize="11" Opacity="0.4" Margin="4,0,0,2" />
                    <TextBlock Text="{Binding SelectedNode.Id}" FontSize="10" Opacity="0.3" Margin="4,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <!-- Separator -->
                <Separator Margin="0,4" />

                <!-- Input Parameters -->
                <TextBlock Text="Parameters" FontWeight="SemiBold" FontSize="12" Margin="4,4,0,8" />

                <ItemsControl ItemsSource="{Binding SelectedNode.Properties}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NodePropertyViewModel}">
                            <StackPanel Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" Margin="4,0,0,2">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="11" Opacity="0.7" />
                                    <TextBlock Text=" *" Foreground="#FF5722" FontSize="11"
                                               Visibility="{Binding IsRequired, Converter={StaticResource BoolToVisibility}}" />
                                    <TextBlock Text="{Binding Type, StringFormat=' ({0})'}" FontSize="10" Opacity="0.4" />
                                </StackPanel>
                                <ui:TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="{Binding ParameterDescription}"
                                            PlaceholderText="{Binding Type}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Output Definitions (read-only) -->
                <Separator Margin="0,4" />
                <TextBlock Text="Outputs" FontWeight="SemiBold" FontSize="12" Margin="4,4,0,4" Opacity="0.6" />
                <ItemsControl ItemsSource="{Binding SelectedNode.OutputDefinitions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="{Binding DisplayName}" FontSize="11" Opacity="0.5" />
                                <TextBlock Text="{Binding Type, StringFormat=' : {0}'}" FontSize="10" Opacity="0.3" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Connection Properties -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsConnectionSelected, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Margin="8,4">
                <Border Padding="8" Margin="0,0,0,8" CornerRadius="6"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <TextBlock Text="Connection" FontWeight="Bold" FontSize="13" />
                </Border>

                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="Condition" FontSize="11" Opacity="0.7" Margin="4,0,0,2" />
                    <ui:TextBox Text="{Binding SelectedConnection.Condition, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="e.g., Success, Fail, True, False" />
                </StackPanel>

                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="Source Node ID" FontSize="11" Opacity="0.4" Margin="4,0,0,2" />
                    <TextBlock Text="{Binding SelectedConnection.SourceNodeId}" FontSize="10" Opacity="0.3"
                               Margin="4,0" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="Target Node ID" FontSize="11" Opacity="0.4" Margin="4,0,0,2" />
                    <TextBlock Text="{Binding SelectedConnection.TargetNodeId}" FontSize="10" Opacity="0.3"
                               Margin="4,0" TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
