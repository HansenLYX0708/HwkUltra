<UserControl x:Class="HWKUltra.UI.Views.Controls.AIAssistantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:HWKUltra.UI.ViewModels.Pages"
             xmlns:converters="clr-namespace:HWKUltra.UI.Helpers"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="320">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Provider selector -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Provider:" VerticalAlignment="Center"
                       FontSize="11" Margin="0,0,4,0" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding AvailableProviders}"
                      SelectedItem="{Binding SelectedProvider}"
                      FontSize="11" />
        </Grid>

        <!-- Quick actions -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,6">
            <ui:Button Content="Explain Node" Tag="explain"
                       FontSize="10" Padding="6,2" Margin="0,0,2,2"
                       Click="QuickAction_Click" />
            <ui:Button Content="Optimize Flow" Tag="optimize"
                       FontSize="10" Padding="6,2" Margin="0,0,2,2"
                       Click="QuickAction_Click" />
            <ui:Button Content="Check Errors" Tag="errors"
                       FontSize="10" Padding="6,2" Margin="0,0,2,2"
                       Click="QuickAction_Click" />
        </WrapPanel>

        <!-- Messages -->
        <Border Grid.Row="2" BorderThickness="1" CornerRadius="4"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ChatMessageItem}">
                            <Border Margin="4" Padding="6" CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding RoleDisplay}"
                                               FontSize="9" FontWeight="SemiBold" Opacity="0.6" />
                                    <TextBlock Text="{Binding Content}"
                                               TextWrapping="Wrap" FontSize="11" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Input -->
        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="50" MaxHeight="100"
                     FontSize="11" Margin="0,0,4,0"
                     KeyDown="UserInput_KeyDown" />
            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                <ui:Button Icon="{ui:SymbolIcon Send24}"
                           Command="{Binding SendCommand}"
                           Appearance="Primary"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                           ToolTip="Send (Ctrl+Enter)"
                           Margin="0,0,0,2" />
                <ui:Button Icon="{ui:SymbolIcon Delete24}"
                           Command="{Binding ClearCommand}"
                           ToolTip="Clear" />
            </StackPanel>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}"
                   FontSize="10" Opacity="0.7"
                   Margin="0,4,0,0" />
    </Grid>
</UserControl>
