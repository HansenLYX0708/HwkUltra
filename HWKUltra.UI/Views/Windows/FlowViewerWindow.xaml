<Window x:Class="HWKUltra.UI.Views.Windows.FlowViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:HWKUltra.UI.Views.Controls"
        x:Name="ThisWindow"
        Title="Sub-Flow Viewer"
        Width="1100" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="10,6"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ui:SymbolIcon Symbol="DocumentArrowUp24" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding BreadcrumbText, ElementName=ThisWindow}"
                               FontSize="12" VerticalAlignment="Center"
                               Opacity="0.85" TextTrimming="CharacterEllipsis" MaxWidth="780" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Icon="{ui:SymbolIcon ZoomOut24}" Appearance="Transparent"
                               Command="{Binding ZoomOutCommand}" Margin="0,0,2,0" />
                    <TextBlock Text="{Binding ZoomLevel, StringFormat='{}{0:P0}'}"
                               VerticalAlignment="Center" FontSize="11" Opacity="0.7" Margin="4,0" />
                    <ui:Button Icon="{ui:SymbolIcon ZoomIn24}" Appearance="Transparent"
                               Command="{Binding ZoomInCommand}" Margin="0,0,2,0" />
                    <ui:Button Icon="{ui:SymbolIcon ArrowMaximize24}" Appearance="Transparent"
                               Command="{Binding ResetZoomCommand}" Margin="0,0,8,0" ToolTip="Reset Zoom" />
                    <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" Content="Open in Editor"
                               Click="OpenInEditor_Click" Appearance="Secondary" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="5" CornerRadius="8" Padding="6"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <controls:FlowCanvas x:Name="FlowCanvasControl" />
        </Border>

        <Border Grid.Row="2" Padding="10,4"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Opacity="0.7" FontSize="12" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Right-click SubFlow / Parallel nodes to open their children in new windows"
                               Opacity="0.5" FontSize="11" Margin="0,0,16,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding NodeCount, StringFormat='Nodes: {0}'}" Margin="0,0,12,0"
                               Opacity="0.7" FontSize="12" />
                    <TextBlock Text="{Binding ConnectionCount, StringFormat='Connections: {0}'}"
                               Opacity="0.7" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
