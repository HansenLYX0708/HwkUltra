<Page x:Class="HWKUltra.UI.Views.Pages.CreatorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:HWKUltra.UI.Views.Pages"
      xmlns:controls="clr-namespace:HWKUltra.UI.Views.Controls"
      xmlns:converters="clr-namespace:HWKUltra.UI.Helpers"
      mc:Ignorable="d"
      Title="CreatorPage"
      d:DataContext="{d:DesignInstance local:CreatorPage, IsDesignTimeCreatable=False}"
      d:DesignHeight="650"
      d:DesignWidth="1100"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="8,4" 
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <ui:Button Icon="{ui:SymbolIcon DocumentAdd24}" Content="New" 
                           Command="{Binding ViewModel.NewFlowCommand}" Margin="0,0,4,0"
                           Appearance="Transparent" />
                <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" Content="Open" 
                           Command="{Binding ViewModel.OpenFlowCommand}" Margin="0,0,4,0"
                           Appearance="Transparent" />
                <ui:Button Icon="{ui:SymbolIcon Save24}" Content="Save" 
                           Command="{Binding ViewModel.SaveFlowCommand}" Margin="0,0,4,0"
                           Appearance="Transparent" />
                <ui:Button Icon="{ui:SymbolIcon SaveCopy24}" Content="Save As" 
                           Command="{Binding ViewModel.SaveAsFlowCommand}" Margin="0,0,4,0"
                           Appearance="Transparent" />
                <Separator Margin="8,4" />
                <ui:Button Icon="{ui:SymbolIcon Delete24}" Content="Delete" 
                           Command="{Binding ViewModel.DeleteSelectedCommand}" Margin="0,0,4,0"
                           Appearance="Transparent" ToolTip="Delete selected (Del)" />
                <ui:Button Icon="{ui:SymbolIcon ArrowSwap24}" Content="Flip"
                           Command="{Binding ViewModel.FlipSelectedCommand}" Margin="0,0,4,0"
                           Appearance="Transparent" ToolTip="Flip selected nodes (F)" />
                <ui:Button Icon="{ui:SymbolIcon SelectAllOn24}" Content="Select All"
                           Command="{Binding ViewModel.SelectAllCommand}" Margin="0,0,4,0"
                           Appearance="Transparent" ToolTip="Select all nodes (Ctrl+A)" />
                <Separator Margin="8,4" />
                <ui:Button Icon="{ui:SymbolIcon ZoomOut24}" Content="Zoom Out" 
                           Command="{Binding ViewModel.ZoomOutCommand}" Margin="0,0,4,0"
                           Appearance="Transparent" />
                <TextBlock Text="{Binding ViewModel.ZoomLevel, StringFormat='{}{0:P0}'}" 
                           VerticalAlignment="Center" FontSize="12" Margin="4,0" Opacity="0.7" />
                <ui:Button Icon="{ui:SymbolIcon ZoomIn24}" Content="Zoom In" 
                           Command="{Binding ViewModel.ZoomInCommand}" Margin="0,0,4,0"
                           Appearance="Transparent" />
                <ui:Button Icon="{ui:SymbolIcon ArrowMaximize24}" Content="Fit" 
                           Command="{Binding ViewModel.ResetZoomCommand}" Margin="0,0,4,0"
                           Appearance="Transparent" />
            </StackPanel>
        </Border>

        <!-- Main Editor Area -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: Node Toolbox -->
            <Border Grid.Column="0" CornerRadius="8" Padding="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
                <controls:NodeToolbox DataContext="{Binding ViewModel}"/>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Center: Flow Canvas -->
            <Border Grid.Column="2" CornerRadius="8" Padding="12"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                <controls:FlowCanvas x:Name="FlowCanvasControl" DataContext="{Binding ViewModel}" />
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Right: Property Panel -->
            <Border Grid.Column="4" CornerRadius="8" Padding="12"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                <controls:PropertyPanel DataContext="{Binding ViewModel}" />
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="5" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Far-Right: AI Assistant Panel (collapsible) -->
            <Expander Grid.Column="6" ExpandDirection="Left"
                      Header="AI" IsExpanded="False"
                      VerticalAlignment="Stretch">
                <Border CornerRadius="8" Padding="12" Width="340"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <controls:AIAssistantPanel x:Name="AIPanel" />
                </Border>
            </Expander>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Padding="8,4"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="{Binding ViewModel.StatusText}" 
                           VerticalAlignment="Center" Opacity="0.7" FontSize="12" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Middle-drag: Pan | Ctrl+Click: Multi-select | Drag canvas: Rubber-band | F: Flip"
                               Opacity="0.4" FontSize="10" Margin="0,0,20,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ViewModel.NodeCount, StringFormat='Nodes: {0}'}" 
                               Margin="0,0,16,0" Opacity="0.7" FontSize="12" />
                    <TextBlock Text="{Binding ViewModel.ConnectionCount, StringFormat='Connections: {0}'}" 
                               Opacity="0.7" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
