<Page
    x:Class="HWKUltra.UI.Views.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:HWKUltra.UI.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:HWKUltra.UI.Helpers"
    Title="Login"
    d:DataContext="{d:DesignInstance local:LoginPage, IsDesignTimeCreatable=False}"
    d:DesignHeight="650"
    d:DesignWidth="1100"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibility" />
    </Page.Resources>

    <Grid>
        <!-- Center login card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="380" MaxWidth="420"
                Padding="32" CornerRadius="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1">
            <StackPanel>
                <!-- Logo + Title -->
                <Image Source="pack://application:,,,/Assets/hawkeye-ultra-icon-256.png"
                       Width="64" Height="64" Margin="0,0,0,12"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="Hawkeye Ultra"
                           FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                <TextBlock Text="AOI Inspection Platform"
                           FontSize="12" Opacity="0.5"
                           HorizontalAlignment="Center" Margin="0,0,0,24" />

                <!-- Mode Toggle -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Column="0" Content="Offline"
                                 IsChecked="{Binding ViewModel.IsOfflineMode, Mode=TwoWay}"
                                 HorizontalAlignment="Center"
                                 GroupName="AuthMode" />
                    <RadioButton Grid.Column="1" Content="Online"
                                 IsChecked="{Binding ViewModel.IsOfflineMode, Mode=TwoWay, Converter={StaticResource InverseBool}}"
                                 HorizontalAlignment="Center"
                                 GroupName="AuthMode" />
                </Grid>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" Opacity="0.6" Margin="0,0,0,4" />
                <ui:TextBox x:Name="UsernameBox"
                            Text="{Binding ViewModel.Username, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Enter username"
                            Margin="0,0,0,12" />

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" Opacity="0.6" Margin="0,0,0,4" />
                <ui:PasswordBox x:Name="PasswordBox"
                                PlaceholderText="Enter password"
                                Margin="0,0,0,8"
                                PasswordChanged="PasswordBox_PasswordChanged" />

                <!-- Error message -->
                <TextBlock Text="{Binding ViewModel.ErrorMessage}"
                           Foreground="#F44336" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,12"
                           Visibility="{Binding ViewModel.ErrorMessage, Converter={StaticResource StringToVisibility}}" />

                <!-- Login button -->
                <ui:Button Content="Login" Appearance="Primary"
                           HorizontalAlignment="Stretch"
                           IsEnabled="{Binding ViewModel.IsLoggingIn, Converter={StaticResource InverseBool}}"
                           Command="{Binding ViewModel.LoginCommand}"
                           Margin="0,8,0,0" />

                <!-- Loading indicator -->
                <ui:ProgressRing Width="24" Height="24" Margin="0,12,0,0"
                                 HorizontalAlignment="Center"
                                 Visibility="{Binding ViewModel.IsLoggingIn, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
