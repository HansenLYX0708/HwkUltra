<Page
  x:Class="HWKUltra.UI.Views.Pages.NodeTestPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:HWKUltra.UI.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:vm="clr-namespace:HWKUltra.UI.ViewModels.Pages"
  xmlns:models="clr-namespace:HWKUltra.UI.Models"
  xmlns:converters="clr-namespace:HWKUltra.UI.Helpers"
  Title="NodeTestPage"
  d:DataContext="{d:DesignInstance local:NodeTestPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="700"
  d:DesignWidth="1200"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <converters:StringToBrushConverter x:Key="StringToBrush" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:InverseNullToVisibilityConverter x:Key="InverseNullToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <BooleanToVisibilityConverter x:Key="StdBoolToVisibility" />
    </Page.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" MinWidth="300" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT: Device Environment ===== -->
        <Border Grid.Column="0" CornerRadius="8" Padding="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="Device Environment" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

                <!-- Simulation Toggle -->
                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <ui:ToggleSwitch Content="Simulation Mode"
                                     IsChecked="{Binding ViewModel.UseSimulation, Mode=TwoWay}" />
                </StackPanel>

                <!-- Device Config Paths -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                    <StackPanel IsEnabled="{Binding ViewModel.UseSimulation, Converter={StaticResource InverseBool}}">
                        <!-- Motion -->
                        <TextBlock Text="Motion" FontSize="11" Opacity="0.7" Margin="0,4,0,2" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding ViewModel.MotionConfigPath, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Motion config JSON" FontSize="11" />
                            <ui:Button Grid.Column="1" Content="..." Margin="4,0,0,0" Padding="8,4"
                                       Command="{Binding ViewModel.BrowseConfigCommand}" CommandParameter="Motion" />
                        </Grid>

                        <!-- IO -->
                        <TextBlock Text="IO" FontSize="11" Opacity="0.7" Margin="0,6,0,2" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding ViewModel.IoConfigPath, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="IO config JSON" FontSize="11" />
                            <ui:Button Grid.Column="1" Content="..." Margin="4,0,0,0" Padding="8,4"
                                       Command="{Binding ViewModel.BrowseConfigCommand}" CommandParameter="IO" />
                        </Grid>

                        <!-- LightSource -->
                        <TextBlock Text="LightSource" FontSize="11" Opacity="0.7" Margin="0,6,0,2" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding ViewModel.LightSourceConfigPath, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="LightSource config JSON" FontSize="11" />
                            <ui:Button Grid.Column="1" Content="..." Margin="4,0,0,0" Padding="8,4"
                                       Command="{Binding ViewModel.BrowseConfigCommand}" CommandParameter="LightSource" />
                        </Grid>

                        <!-- Camera -->
                        <TextBlock Text="Camera" FontSize="11" Opacity="0.7" Margin="0,6,0,2" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding ViewModel.CameraConfigPath, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Camera config JSON" FontSize="11" />
                            <ui:Button Grid.Column="1" Content="..." Margin="4,0,0,0" Padding="8,4"
                                       Command="{Binding ViewModel.BrowseConfigCommand}" CommandParameter="Camera" />
                        </Grid>

                        <!-- AutoFocus -->
                        <TextBlock Text="AutoFocus" FontSize="11" Opacity="0.7" Margin="0,6,0,2" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding ViewModel.AutoFocusConfigPath, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="AutoFocus config JSON" FontSize="11" />
                            <ui:Button Grid.Column="1" Content="..." Margin="4,0,0,0" Padding="8,4"
                                       Command="{Binding ViewModel.BrowseConfigCommand}" CommandParameter="AutoFocus" />
                        </Grid>

                        <!-- Measurement -->
                        <TextBlock Text="Measurement" FontSize="11" Opacity="0.7" Margin="0,6,0,2" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding ViewModel.MeasurementConfigPath, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Measurement config JSON" FontSize="11" />
                            <ui:Button Grid.Column="1" Content="..." Margin="4,0,0,0" Padding="8,4"
                                       Command="{Binding ViewModel.BrowseConfigCommand}" CommandParameter="Measurement" />
                        </Grid>

                        <!-- Tray -->
                        <TextBlock Text="Tray" FontSize="11" Opacity="0.7" Margin="0,6,0,2" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding ViewModel.TrayConfigPath, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Tray config JSON" FontSize="11" />
                            <ui:Button Grid.Column="1" Content="..." Margin="4,0,0,0" Padding="8,4"
                                       Command="{Binding ViewModel.BrowseConfigCommand}" CommandParameter="Tray" />
                        </Grid>

                        <!-- BarcodeScanner -->
                        <TextBlock Text="BarcodeScanner" FontSize="11" Opacity="0.7" Margin="0,6,0,2" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding ViewModel.BarcodeScannerConfigPath, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="BarcodeScanner config JSON" FontSize="11" />
                            <ui:Button Grid.Column="1" Content="..." Margin="4,0,0,0" Padding="8,4"
                                       Command="{Binding ViewModel.BrowseConfigCommand}" CommandParameter="BarcodeScanner" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Buttons + Status -->
                <StackPanel Grid.Row="3">
                    <!-- Load Defaults -->
                    <ui:Button Content="Load Default Configs" Appearance="Info" FontSize="11"
                               HorizontalAlignment="Stretch" Margin="0,0,0,4"
                               IsEnabled="{Binding ViewModel.UseSimulation, Converter={StaticResource InverseBool}}"
                               Command="{Binding ViewModel.LoadDefaultConfigsCommand}" />

                    <!-- Initialize / Reset -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Content="Initialize" Appearance="Primary"
                                   HorizontalAlignment="Stretch"
                                   Command="{Binding ViewModel.InitializeEnvironmentCommand}" />
                        <ui:Button Grid.Column="2" Content="Reset"
                                   HorizontalAlignment="Stretch"
                                   Command="{Binding ViewModel.ResetEnvironmentCommand}" />
                    </Grid>

                    <!-- Connect / Disconnect -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Content="Connect" Appearance="Success" FontSize="11"
                                   HorizontalAlignment="Stretch"
                                   IsEnabled="{Binding ViewModel.IsEnvironmentReady}"
                                   Command="{Binding ViewModel.ConnectDevicesCommand}" />
                        <ui:Button Grid.Column="2" Content="Disconnect" Appearance="Caution" FontSize="11"
                                   HorizontalAlignment="Stretch"
                                   IsEnabled="{Binding ViewModel.IsDevicesConnected}"
                                   Command="{Binding ViewModel.DisconnectDevicesCommand}" />
                    </Grid>

                    <TextBlock Text="{Binding ViewModel.EnvironmentStatus}" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <!-- Environment Log -->
                    <Border MaxHeight="120" Margin="0,4,0,0" CornerRadius="4"
                            BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ViewModel.EnvironmentLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="10" FontFamily="Consolas"
                                                   TextWrapping="NoWrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent"/>

        <!-- ===== CENTER: Node Selection & Configuration ===== -->
        <Border Grid.Column="2" CornerRadius="8" Padding="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="Node Selection &amp; Configuration"
                           FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

                <!-- Search -->
                <ui:AutoSuggestBox Grid.Row="1" PlaceholderText="Search nodes..."
                                   Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,0,8">
                    <ui:AutoSuggestBox.Icon>
                        <ui:IconSourceElement>
                            <ui:SymbolIconSource Symbol="Search24" />
                        </ui:IconSourceElement>
                    </ui:AutoSuggestBox.Icon>
                </ui:AutoSuggestBox>

                <!-- Node Selector (flat grouped list) -->
                <Border Grid.Row="2" MaxHeight="200" Margin="0,0,0,8"
                        BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        CornerRadius="4">
                    <TreeView ItemsSource="{Binding ViewModel.FilteredCategories}" 
                              BorderThickness="0" Background="Transparent"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type models:NodeCatalogCategory}"
                                                      ItemsSource="{Binding Entries}">
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2" Margin="0,0,6,0"
                                               Fill="{Binding Color, Converter={StaticResource StringToBrush}}" />
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:NodeCatalogEntry}">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" Cursor="Hand"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   MouseLeftButtonDown="NodeEntry_Click" Tag="{Binding}" />
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>

                <!-- Selected Node Info + Parameters -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Selected node header -->
                        <Border Padding="8" Margin="0,0,0,8" CornerRadius="6"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                Visibility="{Binding ViewModel.SelectedNodeEntry, Converter={StaticResource NullToVisibility}, FallbackValue=Collapsed}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="0,0,6,0"
                                               Fill="{Binding ViewModel.SelectedNodeEntry.Color, Converter={StaticResource StringToBrush}}" />
                                    <TextBlock Text="{Binding ViewModel.SelectedNodeEntry.DisplayName}" FontWeight="Bold" FontSize="13" />
                                    <TextBlock Text="{Binding ViewModel.SelectedNodeEntry.Type, StringFormat=' ({0})'}" FontSize="11" Opacity="0.5" />
                                </StackPanel>
                                <TextBlock Text="{Binding ViewModel.SelectedNodeEntry.Category}" FontSize="11" Opacity="0.5" />
                            </StackPanel>
                        </Border>

                        <!-- Input Parameters -->
                        <TextBlock Text="Input Parameters" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"
                                   Visibility="{Binding ViewModel.SelectedNodeEntry, Converter={StaticResource NullToVisibility}, FallbackValue=Collapsed}" />

                        <ItemsControl ItemsSource="{Binding ViewModel.NodeProperties}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NodePropertyViewModel}">
                                    <StackPanel Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="11" Opacity="0.7" />
                                            <TextBlock Text=" *" Foreground="#FF5722" FontSize="11"
                                                       Visibility="{Binding IsRequired, Converter={StaticResource BoolToVisibility}}" />
                                            <TextBlock Text="{Binding Type, StringFormat=' ({0})'}" FontSize="10" Opacity="0.4" />
                                        </StackPanel>
                                        <ui:TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                    ToolTip="{Binding ParameterDescription}"
                                                    PlaceholderText="{Binding Type}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Output Definitions (read-only info) -->
                        <Separator Margin="0,4"
                                   Visibility="{Binding ViewModel.SelectedNodeEntry, Converter={StaticResource NullToVisibility}, FallbackValue=Collapsed}" />
                        <TextBlock Text="Output Definitions" FontWeight="SemiBold" FontSize="12" Margin="0,4,0,4" Opacity="0.6"
                                   Visibility="{Binding ViewModel.SelectedNodeEntry, Converter={StaticResource NullToVisibility}, FallbackValue=Collapsed}" />
                        <ItemsControl ItemsSource="{Binding ViewModel.OutputDefinitions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="11" Opacity="0.5" />
                                        <TextBlock Text="{Binding Type, StringFormat=' : {0}'}" FontSize="10" Opacity="0.3" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- No selection message -->
                        <TextBlock Text="Select a node from the list above to configure and test"
                                   Visibility="{Binding ViewModel.SelectedNodeEntry, Converter={StaticResource InverseNullToVisibility}, FallbackValue=Visible}"
                                   Opacity="0.4" FontSize="12" HorizontalAlignment="Center" Margin="0,40" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </ScrollViewer>

                <!-- No selection placeholder handled in ScrollViewer above -->
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="3" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent"/>

        <!-- ===== RIGHT: Execution & Output ===== -->
        <Border Grid.Column="4" CornerRadius="8" Padding="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="Execution" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

                <!-- Save as JSON -->
                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <ui:ToggleSwitch Content="Save as JSON" IsChecked="{Binding ViewModel.SaveAsJson, Mode=TwoWay}" />
                    <Grid Margin="0,4,0,0" Visibility="{Binding ViewModel.SaveAsJson, Converter={StaticResource StdBoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" Text="{Binding ViewModel.SaveJsonPath, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Save path" FontSize="11" />
                        <ui:Button Grid.Column="1" Content="..." Margin="4,0,0,0" Padding="8,4"
                                   Command="{Binding ViewModel.BrowseSavePathCommand}" />
                    </Grid>
                </StackPanel>

                <!-- Execute / Cancel buttons -->
                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:Button Grid.Column="0" Content="Execute" Appearance="Primary"
                               HorizontalAlignment="Stretch"
                               IsEnabled="{Binding ViewModel.IsExecuting, Converter={StaticResource InverseBool}, FallbackValue=True}"
                               Command="{Binding ViewModel.ExecuteNodeCommand}" />
                    <ui:Button Grid.Column="2" Content="Cancel" Appearance="Danger"
                               IsEnabled="{Binding ViewModel.IsExecuting}"
                               Command="{Binding ViewModel.CancelExecutionCommand}" />
                </Grid>

                <!-- Execution Result -->
                <Border Grid.Row="3" Padding="8" Margin="0,0,0,8" CornerRadius="4"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                    <StackPanel>
                        <TextBlock Text="Result" FontSize="11" Opacity="0.5" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding ViewModel.ExecutionResult}" FontWeight="SemiBold" FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Output Values -->
                <StackPanel Grid.Row="4">
                    <TextBlock Text="Output Values" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding ViewModel.OutputValues}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name, StringFormat='{}{0}: '}" FontSize="11" Opacity="0.6" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11" FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,4" />

                    <!-- Console Output Log -->
                    <TextBlock Text="Console Output" FontWeight="SemiBold" FontSize="12" Margin="0,4,0,4" />
                    <Border MaxHeight="300" BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      x:Name="OutputLogScroller">
                            <ItemsControl ItemsSource="{Binding ViewModel.OutputLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas"
                                                   TextWrapping="Wrap" Margin="4,1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
