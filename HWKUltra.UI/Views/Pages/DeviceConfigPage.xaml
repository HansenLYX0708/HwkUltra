<Page
  x:Class="HWKUltra.UI.Views.Pages.DeviceConfigPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:HWKUltra.UI.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:vm="clr-namespace:HWKUltra.UI.ViewModels.Pages"
  xmlns:models="clr-namespace:HWKUltra.UI.Models"
  xmlns:converters="clr-namespace:HWKUltra.UI.Helpers"
  Title="DeviceConfigPage"
  d:DataContext="{d:DesignInstance local:DeviceConfigPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="700"
  d:DesignWidth="1100"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <BooleanToVisibilityConverter x:Key="StdBoolToVisibility" />
    </Page.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== TOP: Toolbar ===== -->
        <Border Grid.Row="0" CornerRadius="8" Padding="12,8" Margin="0,0,0,8"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Device Type Selector -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Device:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" />
                    <ComboBox Width="160" ItemsSource="{Binding ViewModel.DeviceTypes}"
                              SelectedItem="{Binding ViewModel.SelectedDeviceType}"
                              DisplayMemberPath="Name" />
                </StackPanel>

                <!-- Config File Selector -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Config:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" />
                    <ComboBox Width="200" ItemsSource="{Binding ViewModel.AvailableConfigs}"
                              SelectedItem="{Binding ViewModel.SelectedConfigFile}" />
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Content="New" Icon="{ui:SymbolIcon DocumentAdd24}" Margin="0,0,4,0"
                               Command="{Binding ViewModel.NewConfigCommand}" />
                    <ui:Button Content="Import" Icon="{ui:SymbolIcon FolderOpen24}" Margin="0,0,4,0"
                               Command="{Binding ViewModel.ImportConfigCommand}" />
                    <ui:Button Content="Save" Icon="{ui:SymbolIcon Save24}" Appearance="Primary" Margin="0,0,4,0"
                               IsEnabled="{Binding ViewModel.IsConfigLoaded}"
                               Command="{Binding ViewModel.SaveConfigCommand}" />
                    <ui:Button Content="Save As" Icon="{ui:SymbolIcon SaveCopy24}" Margin="0,0,4,0"
                               IsEnabled="{Binding ViewModel.IsConfigLoaded}"
                               Command="{Binding ViewModel.SaveConfigAsCommand}" />
                    <ui:Button Content="Validate" Icon="{ui:SymbolIcon CheckmarkCircle24}"
                               IsEnabled="{Binding ViewModel.IsConfigLoaded}"
                               Command="{Binding ViewModel.ValidateConfigCommand}" />
                </StackPanel>

                <!-- File Path + Modified indicator -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ViewModel.CurrentFilePath}" FontSize="11" MaxWidth="300"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text=" *" FontWeight="Bold" Foreground="Orange"
                               Visibility="{Binding ViewModel.IsModified, Converter={StaticResource BoolToVisibility}}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== CENTER: Config Editor ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- Property Editor -->
            <Border Grid.Column="0" CornerRadius="8" Padding="12"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Configuration Properties" FontWeight="SemiBold" FontSize="14"
                               Margin="0,0,0,8" />

                    <!-- Not loaded placeholder -->
                    <TextBlock Grid.Row="1" Text="No config loaded. Select a device type and config file, or click New/Import."
                               FontSize="12" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Visibility="{Binding ViewModel.IsConfigLoaded, Converter={StaticResource InverseBoolToVisibility}}" />

                    <!-- Dynamic property tree -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding ViewModel.IsConfigLoaded, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl ItemsSource="{Binding ViewModel.Properties}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:JsonPropertyModel}">
                                    <local:JsonPropertyEditor Margin="0,0,0,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Validation / Info Panel -->
            <Border Grid.Column="2" CornerRadius="8" Padding="12"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Validation" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ViewModel.ValidationLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas"
                                               TextWrapping="Wrap" Margin="0,0,0,2"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== BOTTOM: Status Bar ===== -->
        <Border Grid.Row="2" CornerRadius="8" Padding="12,6" Margin="0,8,0,0"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <TextBlock Text="{Binding ViewModel.StatusMessage}" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Border>
    </Grid>
</Page>
