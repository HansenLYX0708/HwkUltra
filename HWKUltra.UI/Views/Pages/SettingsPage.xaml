<Page
  x:Class="HWKUltra.UI.Views.Pages.SettingsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:helpers="clr-namespace:HWKUltra.UI.Helpers"
  xmlns:local="clr-namespace:HWKUltra.UI.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="SettingsPage"
  d:DataContext="{d:DesignInstance local:SettingsPage,
                                     IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
  <Page.Resources>
    <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
  </Page.Resources>
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                CanContentScroll="False"
                PanningMode="VerticalOnly">
    <StackPanel Margin="16">
      <!-- Personalization -->
      <TextBlock FontSize="20" FontWeight="Medium" Text="Personalization" />
      <TextBlock Margin="0,12,0,0" Text="Theme" />
      <RadioButton
        Margin="0,12,0,0"
        Command="{Binding ViewModel.ChangeThemeCommand, Mode=OneWay}"
        CommandParameter="theme_light"
        Content="Light"
        GroupName="themeSelect"
        IsChecked="{Binding ViewModel.CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light, Mode=OneWay}"
      />
      <RadioButton
        Margin="0,8,0,0"
        Command="{Binding ViewModel.ChangeThemeCommand, Mode=OneWay}"
        CommandParameter="theme_dark"
        Content="Dark"
        GroupName="themeSelect"
        IsChecked="{Binding ViewModel.CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark, Mode=OneWay}"
      />

      <!-- Paths -->
      <TextBlock Margin="0,24,0,0" FontSize="20" FontWeight="Medium" Text="Paths" />

      <TextBlock Margin="0,12,0,4" Text="Node Catalog Config" />
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ui:TextBox Grid.Column="0"
                    Text="{Binding ViewModel.NodeCatalogConfigPath, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Local/configs/NodeCatalog.json"
                    IsReadOnly="True" />
        <ui:Button Grid.Column="1"
                   Margin="8,0,0,0"
                   Content="Browse"
                   Command="{Binding ViewModel.BrowseNodeCatalogConfigCommand}"
                   Appearance="Secondary" />
      </Grid>

      <TextBlock Margin="0,12,0,4" Text="Default Flow Directory" />
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ui:TextBox Grid.Column="0"
                    Text="{Binding ViewModel.DefaultFlowDirectory, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="ConfigJson/Flow"
                    IsReadOnly="True" />
        <ui:Button Grid.Column="1"
                   Margin="8,0,0,0"
                   Content="Browse"
                   Command="{Binding ViewModel.BrowseDefaultFlowDirectoryCommand}"
                   Appearance="Secondary" />
      </Grid>

      <!-- Canvas -->
      <TextBlock Margin="0,24,0,0" FontSize="20" FontWeight="Medium" Text="Canvas" />

      <TextBlock Margin="0,12,0,4" Text="Grid Size" />
      <ui:NumberBox
        Value="{Binding ViewModel.CanvasGridSize, Mode=TwoWay}"
        Minimum="5" Maximum="100" SmallChange="5"
        SpinButtonPlacementMode="Inline" />

      <CheckBox
        Margin="0,12,0,0"
        Content="Snap to Grid"
        IsChecked="{Binding ViewModel.CanvasSnapToGrid, Mode=TwoWay}" />

      <!-- About -->
      <TextBlock Margin="0,24,0,0" FontSize="20" FontWeight="Medium" Text="About HWKUltra.UI" />
      <TextBlock Margin="0,12,0,0" Text="{Binding ViewModel.AppVersion, Mode=OneWay}" />
    </StackPanel>
  </ScrollViewer>
</Page>
