<Page x:Class="HWKUltra.UI.Views.Pages.AIChatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:HWKUltra.UI.ViewModels.Pages"
      xmlns:converters="clr-namespace:HWKUltra.UI.Helpers"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      d:DataContext="{d:DesignInstance vm:AIChatViewModel}"
      mc:Ignorable="d"
      Title="AI Assistant"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ui:Card Grid.Row="0" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Provider:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableProviders}"
                          SelectedItem="{Binding SelectedProvider}"
                          Width="160" Margin="0,0,16,0" />

                <TextBlock Grid.Column="2" Text="Model:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="3"
                         Text="{Binding ModelOverride, UpdateSourceTrigger=PropertyChanged}"
                         Width="180" Margin="0,0,16,0"
                         ToolTip="Leave empty to use provider's default model" />

                <ui:Button Grid.Column="5" Content="Test"
                           Command="{Binding TestConnectionCommand}"
                           Icon="{ui:SymbolIcon Pulse24}"
                           Margin="0,0,4,0" />
                <ui:Button Grid.Column="6" Content="Clear"
                           Command="{Binding ClearCommand}"
                           Icon="{ui:SymbolIcon Delete24}" />
            </Grid>
        </ui:Card>

        <!-- Chat messages -->
        <ui:Card Grid.Row="1" Margin="0,0,0,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ChatMessageItem}">
                            <Border Margin="0,4" Padding="10" CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                        <Setter Property="MaxWidth" Value="700" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding RoleDisplay}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.7"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding Content}"
                                               TextWrapping="Wrap"
                                               FontSize="13" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </ui:Card>

        <!-- Input area -->
        <ui:Card Grid.Row="2" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="60" MaxHeight="140"
                         Margin="0,0,8,0"
                         KeyDown="UserInput_KeyDown" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <ui:Button Content="Send"
                               Command="{Binding SendCommand}"
                               Icon="{ui:SymbolIcon Send24}"
                               Appearance="Primary"
                               IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                               Margin="0,0,4,0" />
                    <ui:Button Content="Cancel"
                               Command="{Binding CancelCommand}"
                               Icon="{ui:SymbolIcon Stop24}"
                               Appearance="Danger"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- Status bar -->
        <ui:Card Grid.Row="3" Padding="8,4">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </ui:Card>
    </Grid>
</Page>
