<Page x:Class="HWKUltra.UI.Views.Pages.TeachDataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:HWKUltra.UI.ViewModels.Pages"
      d:DataContext="{d:DesignInstance vm:TeachDataViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Teach Data"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ui:Card Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <ui:Button Content="Open" Icon="{ui:SymbolIcon FolderOpen24}"
                           Command="{Binding OpenCommand}" Margin="0,0,4,0" />
                <ui:Button Content="Save" Icon="{ui:SymbolIcon Save24}"
                           Command="{Binding SaveCommand}" Margin="0,0,4,0" />
                <ui:Button Content="Save As" Icon="{ui:SymbolIcon SaveEdit24}"
                           Command="{Binding SaveAsCommand}" Margin="0,0,16,0" />
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,4" />
                <TextBlock Text="{Binding FilePath}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="11" Margin="8,0" TextTrimming="CharacterEllipsis" MaxWidth="400" />
                <TextBlock Text="*" Visibility="{Binding IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}"
                           VerticalAlignment="Center" Foreground="Orange" FontWeight="Bold" FontSize="14" />
            </StackPanel>
        </ui:Card>

        <!-- Main Content: 3-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- Left: Groups -->
            <Border Grid.Column="0" CornerRadius="8" Padding="12"
        Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid>
                    <!--<ui:Card Margin="5" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" >-->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Groups" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

                            <ListBox Grid.Row="1"
                 ItemsSource="{Binding Groups}"
                 SelectedItem="{Binding SelectedGroup}"
                 DisplayMemberPath="Name"
                 Background="Transparent"
                 BorderThickness="0" />

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <ui:Button Icon="{ui:SymbolIcon Add24}" ToolTip="Add Group"
                       Command="{Binding AddGroupCommand}" Appearance="Success"
                       Margin="0,0,4,0" />
                                <ui:Button Icon="{ui:SymbolIcon Delete24}" ToolTip="Remove Group"
                       Command="{Binding RemoveGroupCommand}" Appearance="Danger" />
                            </StackPanel>
                        </Grid>
                    <!--</ui:Card>-->
                </Grid>
            </Border>


            

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Center: Positions list -->
            <Border Grid.Column="2" CornerRadius="8" Padding="12"
Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4">
                        <Run Text="Positions" />
                        <Run Text=" — " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Run Text="{Binding SelectedGroup.Name, Mode=OneWay, FallbackValue='(none)'}"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </TextBlock>

                    <!-- Group metadata -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,0,4,0"
                                   FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBox Grid.Column="1" Text="{Binding SelectedGroup.Description, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="11" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="2" Text="Required Axes:" VerticalAlignment="Center" Margin="0,0,4,0"
                                   FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBox Grid.Column="3" Text="{Binding SelectedGroup.RequiredAxes, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="11" />
                    </Grid>

                    <!-- Position list -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding FilteredPositions}"
                              SelectedItem="{Binding SelectedPosition}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              IsReadOnly="False"
                              SelectionMode="Single"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Axes" Binding="{Binding AxesSummary, Mode=OneWay}" Width="2*" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Icon="{ui:SymbolIcon Add24}" ToolTip="Add Position"
                                   Command="{Binding AddPositionCommand}" Appearance="Success"
                                   Margin="0,0,4,0" />
                        <ui:Button Icon="{ui:SymbolIcon Delete24}" ToolTip="Remove Position"
                                   Command="{Binding RemovePositionCommand}" Appearance="Danger"
                                   Margin="0,0,4,0" />
                        <ui:Button Icon="{ui:SymbolIcon Copy24}" ToolTip="Duplicate Position"
                                   Command="{Binding DuplicatePositionCommand}" />
                    </StackPanel>
                </Grid>

            </Border>
            <!--<ui:Card Grid.Column="2" Margin="4,0,4,0">-->
            <!--</ui:Card>-->

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Right: Axis editor -->
            <Border Grid.Column="4" CornerRadius="8" Padding="12"
Background="{DynamicResource ControlFillColorDefaultBrush}">
                <!--<ui:Card Grid.Column="4" Margin="4,0,0,0">-->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8">
                        <Run Text="Axes — " />
                        <Run Text="{Binding SelectedPosition.Name, Mode=OneWay, FallbackValue='(none)'}"
                             Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        </TextBlock>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedAxes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:AxisValueViewModel}">
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding AxisName, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="12" FontWeight="SemiBold" Margin="0,0,4,0" />
                                        <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=LostFocus, StringFormat=F4}"
                                             FontSize="12" HorizontalContentAlignment="Right" Margin="0,0,4,0" />
                                        <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Dismiss24}"
                                               ToolTip="Remove axis" Appearance="Secondary"
                                               Command="{Binding DataContext.RemoveAxisCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}" Padding="4" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ui:Button Grid.Row="2" Content="Add Axis" Icon="{ui:SymbolIcon Add24}"
                               Command="{Binding AddAxisCommand}" Margin="0,8,0,0"
                               HorizontalAlignment="Left" />
                    </Grid>
                <!--</ui:Card>-->

            </Border>
        </Grid>

        <!-- Status Bar -->
        <ui:Card Grid.Row="2" Margin="0,8,0,0" Padding="8,4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </ui:Card>
    </Grid>
</Page>
