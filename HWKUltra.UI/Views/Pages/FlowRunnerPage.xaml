<Page
  x:Class="HWKUltra.UI.Views.Pages.FlowRunnerPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:local="clr-namespace:HWKUltra.UI.Views.Pages"
  xmlns:vm="clr-namespace:HWKUltra.UI.ViewModels.Pages"
  xmlns:converters="clr-namespace:HWKUltra.UI.Helpers"
  Title="Flow Runner"
  d:DataContext="{d:DesignInstance local:FlowRunnerPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="700"
  d:DesignWidth="1100"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- Log level to color -->
        <Style x:Key="LogLevelStyle" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="ERROR">
                    <Setter Property="Foreground" Value="#F44336" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="WARN">
                    <Setter Property="Foreground" Value="#FF9800" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="SUCCESS">
                    <Setter Property="Foreground" Value="#4CAF50" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="NODE">
                    <Setter Property="Foreground" Value="#2196F3" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="INFO">
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== ROW 1: Toolbar ===== -->
        <Border Grid.Row="0" Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="8" Padding="8" Margin="0,0,0,8">
            <WrapPanel>
                <!-- Import -->
                <ui:Button Content="Import Flow"
                           Icon="{ui:SymbolIcon FolderOpen24}"
                           Appearance="Primary"
                           Command="{Binding ViewModel.ImportFlowCommand}"
                           Margin="0,0,6,0" />

                <ui:Button Content="Open Recent"
                           Icon="{ui:SymbolIcon History24}"
                           Command="{Binding ViewModel.OpenRecentCommand}"
                           Margin="0,0,16,0" />

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,4,16,4" />

                <!-- Execution controls -->
                <ui:Button Content="Execute"
                           Icon="{ui:SymbolIcon Play24}"
                           Appearance="Success"
                           Command="{Binding ViewModel.ExecuteCommand}"
                           Margin="0,0,6,0" />

                <ui:Button Content="Pause"
                           Icon="{ui:SymbolIcon Pause24}"
                           Appearance="Caution"
                           Command="{Binding ViewModel.PauseCommand}"
                           Margin="0,0,6,0" />

                <ui:Button Content="Resume"
                           Icon="{ui:SymbolIcon PlayCircle24}"
                           Appearance="Success"
                           Command="{Binding ViewModel.ResumeCommand}"
                           Margin="0,0,6,0" />

                <ui:Button Content="Stop"
                           Icon="{ui:SymbolIcon Stop24}"
                           Appearance="Danger"
                           Command="{Binding ViewModel.StopCommand}"
                           Margin="0,0,16,0" />

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,4,16,4" />

                <!-- Log actions -->
                <ui:Button Content="Clear Log"
                           Icon="{ui:SymbolIcon Delete24}"
                           Command="{Binding ViewModel.ClearLogCommand}"
                           Margin="0,0,6,0" />

                <ui:Button Content="Export"
                           Icon="{ui:SymbolIcon Save24}"
                           Command="{Binding ViewModel.ExportLogCommand}" />

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="16,4,16,4" />

                <!-- Simulation toggle -->
                <CheckBox Content="Simulation Mode"
                          IsChecked="{Binding ViewModel.UseSimulation}"
                          VerticalAlignment="Center" />
            </WrapPanel>
        </Border>

        <!-- ===== ROW 2: Flow Info + Progress ===== -->
        <Border Grid.Row="1" Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="8" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Flow name -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <ui:SymbolIcon Symbol="Document24" FontSize="18" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding ViewModel.FlowName}" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Timer -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:SymbolIcon Symbol="Timer24" FontSize="16" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding ViewModel.ElapsedTime}" FontSize="20" FontWeight="Bold"
                               FontFamily="Consolas" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Description + path -->
                <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                           Text="{Binding ViewModel.FlowDescription}" Opacity="0.7"
                           TextTrimming="CharacterEllipsis" Margin="26,0,0,4" />
                <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                           Text="{Binding ViewModel.FlowFilePath}" Opacity="0.5" FontSize="11"
                           TextTrimming="CharacterEllipsis" Margin="26,0,0,0" />
            </Grid>
        </Border>

        <!-- ===== ROW 3: Execution Log + Sharpness Results ===== -->
        <Border Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="300" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="480"
                                      MinWidth="320"
                                      MaxWidth="800">
                            <ColumnDefinition.Style>
                                <Style TargetType="ColumnDefinition">
                                    <Setter Property="Width" Value="0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.HasSharpnessResults}" Value="True">
                                            <Setter Property="Width" Value="480" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ColumnDefinition.Style>
                        </ColumnDefinition>
                    </Grid.ColumnDefinitions>

                <!-- === Execution Log (Left) === -->
                    <Border Grid.Column="0" Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="4">
                        <Grid MaxHeight="600">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4,8,4">
                                <ui:SymbolIcon Symbol="TextDescription24" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="Execution Log" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ViewModel.LogEntries.Count, StringFormat=' ({0} entries)'}"
                                   Opacity="0.6" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Log list -->
                            <ListBox Grid.Row="1" x:Name="LogListBox"
                         ItemsSource="{Binding ViewModel.LogEntries}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                           Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"
                                           FontFamily="Consolas" FontSize="12" Opacity="0.6" />
                                            <TextBlock Grid.Column="1"
                                           Text="{Binding Level, StringFormat=[{0}]}"
                                           FontFamily="Consolas" FontSize="12"
                                           Style="{StaticResource LogLevelStyle}" />
                                            <TextBlock Grid.Column="2"
                                           Text="{Binding Message}"
                                           FontSize="12" TextWrapping="Wrap"
                                           Style="{StaticResource LogLevelStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                <!-- === Splitter === -->
                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="Transparent"
                          Visibility="{Binding ViewModel.HasFlowResults, Converter={StaticResource BoolToVis}}" />

                <!-- === Flow Results Summary (Right, compact — no per-row grid to avoid impacting timing) === -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="12"
                    Visibility="{Binding ViewModel.HasFlowResults, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="DataBarVertical24" FontSize="16" Margin="0,0,8,0" />
                            <TextBlock Text="Flow Results" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Count -->
                        <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Rows collected: " FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ViewModel.FlowResultsCount}"
                                       FontFamily="Consolas" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="4,0,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Pool summary (shown when pipeline used an ImagePool) -->
                        <Border Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                            CornerRadius="4" Padding="10,6" Margin="0,0,0,6"
                            Visibility="{Binding ViewModel.HasPoolSummary, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Camera24" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ViewModel.PoolSummary}"
                                       FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- CSV link -->
                        <Grid Visibility="{Binding ViewModel.HasCsvPath, Converter={StaticResource BoolToVis}}"
                          Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                   Text="{Binding ViewModel.FlowResultsCsvPath}"
                                   FontSize="11" Opacity="0.7"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding ViewModel.FlowResultsCsvPath}" />
                            <ui:Button Grid.Column="1"
                                   Content="Open"
                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                   Command="{Binding ViewModel.OpenCsvFolderCommand}"
                                   Margin="6,0,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>
                </ScrollViewer>
    </Grid>
            
        </Border>

        <!-- ===== ROW 4: Status Bar ===== -->
        <Border Grid.Row="3" Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="6" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Run State badge -->
                <Border Grid.Column="0" CornerRadius="4" Padding="8,2" Margin="0,0,12,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#555" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.RunState}" Value="Running">
                                    <Setter Property="Background" Value="#4CAF50" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ViewModel.RunState}" Value="Paused">
                                    <Setter Property="Background" Value="#FF9800" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ViewModel.RunState}" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                </Border>

                <!-- Status text -->
                <TextBlock Grid.Column="1" Text="{Binding ViewModel.StatusText}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                <!-- Current node -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0">
                    <TextBlock Text="Current: " Opacity="0.6" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ViewModel.CurrentNodeName}" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Progress -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <TextBlock Text="Nodes: " Opacity="0.6" VerticalAlignment="Center" />
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}/{1}">
                                <Binding Path="ViewModel.ExecutedNodes" />
                                <Binding Path="ViewModel.TotalNodes" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
