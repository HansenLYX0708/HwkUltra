{
  "id": "folder-sharpness-batch-001",
  "name": "Folder Sharpness Batch",
  "description": "Enumerate a folder of images → parallel sharpness analysis via SharpnessWorker.json. Edit the Folder property to point at your image directory.",
  "createdAt": "2026-04-22T00:00:00",
  "modifiedAt": "2026-04-22T00:00:00",
  "version": "1.0.0",
  "startNodeId": "node-enum",
  "nodes": [
    {
      "id": "node-enum",
      "type": "EnumerateFolder",
      "name": "Enumerate Folder",
      "x": 100,
      "y": 200,
      "properties": {
        "Folder": "C:\\Images\\Test",
        "Pattern": "*.bmp;*.png;*.jpg;*.jpeg;*.tiff",
        "Recursive": "false",
        "SortBy": "Name",
        "OutputVariable": "FileList"
      }
    },
    {
      "id": "node-parallel",
      "type": "Parallel",
      "name": "Parallel Sharpness",
      "x": 380,
      "y": 200,
      "properties": {
        "FlowPaths": "SharpnessWorker.json",
        "ItemsSource": "FileList",
        "WorkerCount": "4",
        "ItemVariable": "CurrentItem",
        "IndexVariable": "CurrentIndex",
        "TotalVariable": "TotalCount"
      }
    },
    {
      "id": "node-save",
      "type": "SaveResultsToCsv",
      "name": "Save CSV",
      "x": 660,
      "y": 200,
      "properties": {
        "Key": "FlowResults",
        "Path": "sharpness_{yyyyMMdd_HHmmss}.csv",
        "Encoding": "UTF8BOM"
      }
    }
  ],
  "connections": [
    {
      "id": "c1",
      "sourceNodeId": "node-enum",
      "targetNodeId": "node-parallel"
    },
    {
      "id": "c2",
      "sourceNodeId": "node-parallel",
      "targetNodeId": "node-save"
    }
  ],
  "globalVariables": []
}
