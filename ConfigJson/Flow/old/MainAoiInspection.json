{
  "id": "main-aoi-inspection-001",
  "name": "Main AOI Inspection",
  "description": "Full AOI inspection: home, barcode scan, parallel dual-stage inspection, result output",
  "version": "1.0.0",
  "startNodeId": "m-home-x",
  "nodes": [
    {
      "id": "m-home-x",
      "type": "AxisHome",
      "name": "Home X Axis",
      "x": 50, "y": 200,
      "properties": { "AxisName": "X" }
    },
    {
      "id": "m-home-y",
      "type": "AxisHome",
      "name": "Home Y Axis",
      "x": 280, "y": 200,
      "properties": { "AxisName": "Y" }
    },
    {
      "id": "m-light-on",
      "type": "LightTurnOnOff",
      "name": "Light On",
      "x": 510, "y": 200,
      "properties": { "ChannelName": "MainLight", "TurnOn": "true" }
    },
    {
      "id": "m-set-running",
      "type": "SetSharedVariable",
      "name": "Set System Running",
      "x": 740, "y": 200,
      "properties": { "Key": "SystemStatus", "Value": "Running" }
    },
    {
      "id": "m-barcode",
      "type": "SubFlow",
      "name": "Scan Barcode",
      "x": 970, "y": 200,
      "properties": { "FlowPath": "ConfigJson/Flow/BarcodeScan.json" }
    },
    {
      "id": "m-parallel",
      "type": "Parallel",
      "name": "Dual-Stage Inspection",
      "x": 1200, "y": 200,
      "properties": {
        "FlowPaths": "ConfigJson/Flow/StageA_Inspection.json,ConfigJson/Flow/StageB_Measurement.json",
        "WaitMode": "All",
        "TimeoutMs": "60000"
      }
    },
    {
      "id": "m-get-result",
      "type": "GetSharedVariable",
      "name": "Get Final Result",
      "x": 1430, "y": 200,
      "properties": { "Key": "InspectionResult", "DefaultValue": "UNKNOWN" }
    },
    {
      "id": "m-light-off",
      "type": "LightTurnOnOff",
      "name": "Light Off",
      "x": 1660, "y": 200,
      "properties": { "ChannelName": "MainLight", "TurnOn": "false" }
    },
    {
      "id": "m-set-done",
      "type": "SetSharedVariable",
      "name": "Set System Done",
      "x": 1890, "y": 200,
      "properties": { "Key": "SystemStatus", "Value": "Done" }
    },
    {
      "id": "m-output",
      "type": "DigitalOutput",
      "name": "Output Done Signal",
      "x": 2120, "y": 200,
      "properties": { "PointName": "InspectionDone", "Value": "true" }
    }
  ],
  "connections": [
    { "id": "c1", "sourceNodeId": "m-home-x", "targetNodeId": "m-home-y" },
    { "id": "c2", "sourceNodeId": "m-home-y", "targetNodeId": "m-light-on" },
    { "id": "c3", "sourceNodeId": "m-light-on", "targetNodeId": "m-set-running" },
    { "id": "c4", "sourceNodeId": "m-set-running", "targetNodeId": "m-barcode" },
    { "id": "c5", "sourceNodeId": "m-barcode", "targetNodeId": "m-parallel" },
    { "id": "c6", "sourceNodeId": "m-parallel", "targetNodeId": "m-get-result" },
    { "id": "c7", "sourceNodeId": "m-get-result", "targetNodeId": "m-light-off" },
    { "id": "c8", "sourceNodeId": "m-light-off", "targetNodeId": "m-set-done" },
    { "id": "c9", "sourceNodeId": "m-set-done", "targetNodeId": "m-output" }
  ],
  "globalVariables": []
}
