{
  "id": "stage-a-inspection-001",
  "name": "Stage A - Visual Inspection",
  "description": "Camera inspection for each tray slot with interlock and signal sync",
  "version": "1.0.0",
  "startNodeId": "a-status",
  "nodes": [
    {
      "id": "a-status",
      "type": "SetSharedVariable",
      "name": "Set StageA Running",
      "x": 50, "y": 200,
      "properties": { "Key": "StageA_Status", "Value": "Running" }
    },
    {
      "id": "a-iter",
      "type": "TrayIterator",
      "name": "Iterate Tray Slots",
      "x": 280, "y": 200,
      "properties": { "InstanceName": "MainTray", "Reset": "true", "FilterState": "-1" }
    },
    {
      "id": "a-lock",
      "type": "AcquireLock",
      "name": "Lock Inspection Zone",
      "x": 510, "y": 200,
      "properties": { "LockName": "InspectionZone", "TimeoutMs": "10000" }
    },
    {
      "id": "a-move",
      "type": "AxisMoveAbs",
      "name": "Move X to Inspect",
      "x": 740, "y": 200,
      "properties": { "AxisName": "X", "Position": "100.0", "Velocity": "50000", "WaitForComplete": "true" }
    },
    {
      "id": "a-grab",
      "type": "CameraGrab",
      "name": "Grab Image",
      "x": 970, "y": 200,
      "properties": { "CameraName": "MainCamera", "TimeoutMs": "5000" }
    },
    {
      "id": "a-delay",
      "type": "Delay",
      "name": "Image Processing",
      "x": 1200, "y": 200,
      "properties": { "Duration": "10", "CanCancel": "true" }
    },
    {
      "id": "a-set-result",
      "type": "SetSharedVariable",
      "name": "Set Vision Result",
      "x": 1430, "y": 200,
      "properties": { "Key": "SlotVisionResult", "Value": "OK" }
    },
    {
      "id": "a-unlock",
      "type": "ReleaseLock",
      "name": "Release Inspection Zone",
      "x": 1660, "y": 200,
      "properties": { "LockName": "InspectionZone" }
    },
    {
      "id": "a-signal-slot",
      "type": "SetSignal",
      "name": "Signal Slot Ready",
      "x": 1890, "y": 200,
      "properties": { "SignalName": "SlotReady", "Value": "inspected" }
    },
    {
      "id": "a-wait-ack",
      "type": "WaitForSignal",
      "name": "Wait Slot Processed",
      "x": 2120, "y": 200,
      "properties": { "SignalName": "SlotProcessed", "TimeoutMs": "10000", "AutoReset": "true" }
    },
    {
      "id": "a-done-status",
      "type": "SetSharedVariable",
      "name": "Set StageA Complete",
      "x": 510, "y": 400,
      "properties": { "Key": "StageA_Status", "Value": "Complete" }
    },
    {
      "id": "a-signal-done",
      "type": "SetSignal",
      "name": "Signal StageA Done",
      "x": 740, "y": 400,
      "properties": { "SignalName": "StageA_AllDone", "Value": "complete" }
    }
  ],
  "connections": [
    { "id": "c1", "sourceNodeId": "a-status", "targetNodeId": "a-iter" },
    { "id": "c2", "sourceNodeId": "a-iter", "targetNodeId": "a-lock", "condition": "Next" },
    { "id": "c3", "sourceNodeId": "a-lock", "targetNodeId": "a-move", "condition": "Acquired" },
    { "id": "c4", "sourceNodeId": "a-move", "targetNodeId": "a-grab" },
    { "id": "c5", "sourceNodeId": "a-grab", "targetNodeId": "a-delay" },
    { "id": "c6", "sourceNodeId": "a-delay", "targetNodeId": "a-set-result" },
    { "id": "c7", "sourceNodeId": "a-set-result", "targetNodeId": "a-unlock" },
    { "id": "c8", "sourceNodeId": "a-unlock", "targetNodeId": "a-signal-slot" },
    { "id": "c9", "sourceNodeId": "a-signal-slot", "targetNodeId": "a-wait-ack" },
    { "id": "c10", "sourceNodeId": "a-wait-ack", "targetNodeId": "a-iter", "condition": "Received" },
    { "id": "c11", "sourceNodeId": "a-iter", "targetNodeId": "a-done-status", "condition": "Done" },
    { "id": "c12", "sourceNodeId": "a-done-status", "targetNodeId": "a-signal-done" }
  ],
  "globalVariables": []
}
