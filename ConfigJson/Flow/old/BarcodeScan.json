{
  "id": "barcode-scan-001",
  "name": "Barcode Scan",
  "description": "Sub-flow: scan product barcode and store in shared context",
  "version": "1.0.0",
  "startNodeId": "bc-trigger",
  "nodes": [
    {
      "id": "bc-trigger",
      "type": "BarcodeScannerTrigger",
      "name": "Trigger Scanner",
      "x": 50, "y": 100,
      "properties": { "InstanceName": "LeftScanner" }
    },
    {
      "id": "bc-getlast",
      "type": "BarcodeScannerGetLast",
      "name": "Get Barcode",
      "x": 280, "y": 100,
      "properties": { "InstanceName": "LeftScanner" }
    },
    {
      "id": "bc-setvar",
      "type": "SetSharedVariable",
      "name": "Store Barcode",
      "x": 510, "y": 100,
      "properties": { "Key": "ProductBarcode", "Value": "SN12345" }
    }
  ],
  "connections": [
    { "id": "c1", "sourceNodeId": "bc-trigger", "targetNodeId": "bc-getlast" },
    { "id": "c2", "sourceNodeId": "bc-getlast", "targetNodeId": "bc-setvar" }
  ],
  "globalVariables": []
}
