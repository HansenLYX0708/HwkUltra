      "properties": {
        "Name": "RightScanPool",
        "Capacity": "6"
      }
    },
    {
      "id": "iter-reset",
      "type": "SetSharedVariable",
      "name": "Reset Iter",
      "x": 301,
      "y": 199,
      "isFlipped": false,
