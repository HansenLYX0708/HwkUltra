{
  "id": "vision-example-flow-001",
  "name": "Vision Processing Example",
  "description": "Demonstrates Vision nodes with various image input methods",
  "createdAt": "2024-04-21T00:00:00",
  "modifiedAt": "2024-04-21T00:00:00",
  "version": "1.0.0",
  "startNodeId": "node-camera-grab",
  "nodes": [
    {
      "id": "node-camera-grab",
      "type": "CameraGrab",
      "name": "Capture Image",
      "description": "Grab image from camera and store in context",
      "x": 50,
      "y": 250,
      "properties": {
        "CameraName": "MainCamera",
        "TimeoutMs": "5000"
      }
    },
    {
      "id": "node-sharpness",
      "type": "GetSharpnessLaplacian",
      "name": "Check Sharpness",
      "description": "Evaluate image sharpness using Laplacian",
      "x": 280,
      "y": 150,
      "properties": {
        "Image": "CapturedBitmap",
        "Width": "",
        "Height": "",
        "Channels": "1"
      }
    },
    {
      "id": "node-find-datum",
      "type": "FindDatum",
      "name": "Find Datum",
      "description": "Locate crosshair datum in image",
      "x": 280,
      "y": 350,
      "properties": {
        "Image": "CapturedBitmap",
        "TemplatePath": "",
        "Width": "",
        "Height": "",
        "Channels": "1"
      }
    },
    {
      "id": "node-branch",
      "type": "Branch",
      "name": "Check Sharpness",
      "description": "Branch if image is sharp enough",
      "x": 510,
      "y": 150,
      "properties": {
        "Condition": "SharpnessScore",
        "Operator": "GreaterThan",
        "CompareValue": "50"
      }
    },
    {
      "id": "node-dl-inference",
      "type": "DLInference",
      "name": "AI Detection",
      "description": "Run deep learning inference",
      "x": 740,
      "y": 150,
      "properties": {
        "Image": "CapturedBitmap",
        "Width": "",
        "Height": "",
        "Channels": "1"
      }
    },
    {
      "id": "node-laser-datum",
      "type": "FindLaserDatum",
      "name": "Laser Center",
      "description": "Find laser datum from raw bytes",
      "x": 510,
      "y": 350,
      "properties": {
        "Image": "RawImageData",
        "Width": "640",
        "Height": "480"
      }
    },
    {
      "id": "node-calibrate",
      "type": "CalibrateCameraMpp",
      "name": "Camera Calibration",
      "description": "Compute mm-per-pixel from calibration image",
      "x": 970,
      "y": 250,
      "properties": {
        "Image": "C:\\Calibration\\CalibrationPattern.bmp",
        "Width": "",
        "Height": "",
        "Channels": "1"
      }
    }
  ],
  "connections": [
    {
      "id": "conn-1",
      "sourceNodeId": "node-camera-grab",
      "targetNodeId": "node-sharpness"
    },
    {
      "id": "conn-2",
      "sourceNodeId": "node-camera-grab",
      "targetNodeId": "node-find-datum"
    },
    {
      "id": "conn-3",
      "sourceNodeId": "node-sharpness",
      "targetNodeId": "node-branch"
    },
    {
      "id": "conn-4",
      "sourceNodeId": "node-branch",
      "targetNodeId": "node-dl-inference",
      "condition": "True"
    },
    {
      "id": "conn-5",
      "sourceNodeId": "node-find-datum",
      "targetNodeId": "node-laser-datum"
    },
    {
      "id": "conn-6",
      "sourceNodeId": "node-dl-inference",
      "targetNodeId": "node-calibrate"
    }
  ],
  "globalVariables": []
}
