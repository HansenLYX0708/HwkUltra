{"id":"hawkeye-image-worker-001","name":"Image Worker Loop","description":"Single image-processing worker. Loops waiting for NewImage signals, pulls job from shared queue, runs algorithm (Measurement/Laser trigger here stands in as inspection stub), writes result back to tray, and repeats. Exits when TestSessionEnd signal is received (via timeout fallback). Step 9/10/12 implementation: async image processing, write result back to tray including defects and error info, multi-threaded (multiple instances of this worker are run in parallel).","createdAt":"2026-04-17T14:57:19.5620414+08:00","modifiedAt":"2026-04-17T14:59:43.8532129+08:00","version":"1.0.0","nodes":[{"id":"w-loop-check","type":"WaitForSignal","name":"Wait NewImage or End","x":176.25,"y":196.25,"isFlipped":false,"properties":{"SignalName":"NewImage","TimeoutMs":"30000","AutoReset":"true"}},{"id":"w-end-check","type":"GetSharedVariable","name":"Check Session End","x":382.5,"y":193.75,"isFlipped":false,"properties":{"Key":"TestRunning","DefaultValue":"false"}},{"id":"w-branch-end","type":"Branch","name":"Session Still Running?","x":596.25,"y":196.25,"isFlipped":false,"properties":{"Condition":"TestRunning","Operator":"Equals","CompareValue":"true"}},{"id":"w-get-job","type":"GetSharedVariable","name":"Get Pending Job","x":806.25,"y":196.25,"isFlipped":false,"properties":{"Key":"ImgJob_Pending_Stage1_Tray1","DefaultValue":""}},{"id":"w-process","type":"MeasurementGetData","name":"Inspect (algorithm stub)","x":1016.25,"y":196.25,"isFlipped":false,"properties":{"InstanceName":"MainSensor","TimeoutMs":"5000"}},{"id":"w-result","type":"SetSharedVariable","name":"Write Defect Result","x":962.5,"y":497.5,"isFlipped":true,"properties":{"Key":"ImgJob_Result_Latest","Value":"Pass","SourceVariable":""}},{"id":"w-write-tray","type":"TraySetSlotState","name":"Write Result to Tray","x":731.2500000000001,"y":500,"isFlipped":true,"properties":{"InstanceName":"Stage1_Tray1","Row":"0","Col":"0","State":"2"}},{"id":"w-process