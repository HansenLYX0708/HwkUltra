{
  "id": "hawkeye-main-001",
  "name": "Hawkeye Main Test Flow",
  "description": "Dual-stage AOI top-level orchestrator. Phase 1: parallel setup (load+IO wait). Phase 2: parallel stage tests + async image processor workers.",
  "version": "1.0.0",
  "startNodeId": "m-init",
  "nodes": [
    {
      "id": "m-init",
      "type": "SetSharedVariable",
      "name": "Init System State",
      "x": 50, "y": 200,
      "properties": { "Key": "TestRunning", "Value": "true" }
    },
    {
      "id": "m-init-s1",
      "type": "SetSharedVariable",
      "name": "Init Stage1 State",
      "x": 260, "y": 200,
      "properties": { "Key": "Stage1_State", "Value": "Idle" }
    },
    {
      "id": "m-init-s2",
      "type": "SetSharedVariable",
      "name": "Init Stage2 State",
      "x": 470, "y": 200,
      "properties": { "Key": "Stage2_State", "Value": "Idle" }
    },
    {
      "id": "m-init-img-count",
      "type": "SetSharedVariable",
      "name": "Init ImageJobCount",
      "x": 680, "y": 200,
      "properties": { "Key": "ImageJobCount", "Value": "0" }
    },
    {
      "id": "m-light-on",
      "type": "LightTurnOnOff",
      "name": "Light On",
      "x": 890, "y": 200,
      "properties": { "ChannelName": "MainLight", "TurnOn": "true" }
    },
    {
      "id": "m-phase1-setup",
      "type": "Parallel",
      "name": "Phase 1: Both Stages Setup (Load + IO Wait)",
      "x": 1100, "y": 200,
      "properties": {
        "FlowPaths": "ConfigJson/Flow/Hawkeye/Stage1_Setup.json,ConfigJson/Flow/Hawkeye/Stage2_Setup.json",
        "WaitMode": "All",
        "TimeoutMs": "600000"
      }
    },
    {
      "id": "m-signal-pretest",
      "type": "SetSignal",
      "name": "Signal Both Stages Ready (Pretest)",
      "x": 1310, "y": 200,
      "properties": { "SignalName": "BothStagesReady", "Value": "pretest" }
    },
    {
      "id": "m-phase2-test",
      "type": "Parallel",
      "name": "Phase 2: Stage Tests + Image Processing",
      "x": 1520, "y": 200,
      "properties": {
        "FlowPaths": "ConfigJson/Flow/Hawkeye/Stage1_Test.json,ConfigJson/Flow/Hawkeye/Stage2_Test.json,ConfigJson/Flow/Hawkeye/ImageProcessor.json",
        "WaitMode": "All",
        "TimeoutMs": "1800000"
      }
    },
    {
      "id": "m-signal-end",
      "type": "SetSignal",
      "name": "Signal Test Session End",
      "x": 1730, "y": 200,
      "properties": { "SignalName": "TestSessionEnd", "Value": "end" }
    },
    {
      "id": "m-light-off",
      "type": "LightTurnOnOff",
      "name": "Light Off",
      "x": 1940, "y": 200,
      "properties": { "ChannelName": "MainLight", "TurnOn": "false" }
    },
    {
      "id": "m-done",
      "type": "SetSharedVariable",
      "name": "Set System Done",
      "x": 2150, "y": 200,
      "properties": { "Key": "TestRunning", "Value": "false" }
    }
  ],
  "connections": [
    { "id": "c1", "sourceNodeId": "m-init", "targetNodeId": "m-init-s1" },
    { "id": "c2", "sourceNodeId": "m-init-s1", "targetNodeId": "m-init-s2" },
    { "id": "c3", "sourceNodeId": "m-init-s2", "targetNodeId": "m-init-img-count" },
    { "id": "c4", "sourceNodeId": "m-init-img-count", "targetNodeId": "m-light-on" },
    { "id": "c5", "sourceNodeId": "m-light-on", "targetNodeId": "m-phase1-setup" },
    { "id": "c6", "sourceNodeId": "m-phase1-setup", "targetNodeId": "m-signal-pretest" },
    { "id": "c7", "sourceNodeId": "m-signal-pretest", "targetNodeId": "m-phase2-test" },
    { "id": "c8", "sourceNodeId": "m-phase2-test", "targetNodeId": "m-signal-end" },
    { "id": "c9", "sourceNodeId": "m-signal-end", "targetNodeId": "m-light-off" },
    { "id": "c10", "sourceNodeId": "m-light-off", "targetNodeId": "m-done" }
  ],
  "globalVariables": []
}
