{
  "id": "hawkeye-stage2-setup-001",
  "name": "Stage2 Setup (Load + IO Wait)",
  "description": "Stage2: move to load position, wait for user to place tray and press start button (IO trigger). On trigger, signal pretest-ready and exit.",
  "version": "1.0.0",
  "startNodeId": "s2-state-wait",
  "nodes": [
    {
      "id": "s2-state-wait",
      "type": "SetSharedVariable",
      "name": "Set Stage2 WaitingLoad",
      "x": 50, "y": 150,
      "properties": { "Key": "Stage2_State", "Value": "WaitingLoad" }
    },
    {
      "id": "s2-move-load",
      "type": "MoveToTeachPosition",
      "name": "Move Stage2 to Load Position",
      "x": 260, "y": 150,
      "properties": {
        "PositionName": "Stage2_LoadPos",
        "GroupName": "Stage2_XYZ",
        "Velocity": "40000",
        "Acceleration": "500000",
        "WaitForComplete": "true"
      }
    },
    {
      "id": "s2-state-io",
      "type": "SetSharedVariable",
      "name": "Set Stage2 WaitingIO",
      "x": 470, "y": 150,
      "properties": { "Key": "Stage2_State", "Value": "WaitingIO" }
    },
    {
      "id": "s2-io-wait",
      "type": "DigitalInput",
      "name": "Wait Stage2 Start Button",
      "x": 680, "y": 150,
      "properties": {
        "InputName": "Stage2_StartButton",
        "WaitForTrue": "true",
        "Timeout": "0"
      }
    },
    {
      "id": "s2-state-pretest",
      "type": "SetSharedVariable",
      "name": "Set Stage2 Pretest",
      "x": 890, "y": 150,
      "properties": { "Key": "Stage2_State", "Value": "Pretest" }
    },
    {
      "id": "s2-signal-ready",
      "type": "SetSignal",
      "name": "Signal Stage2 IO Ready",
      "x": 1100, "y": 150,
      "properties": { "SignalName": "Stage2_IOReady", "Value": "ready" }
    }
  ],
  "connections": [
    { "id": "c1", "sourceNodeId": "s2-state-wait", "targetNodeId": "s2-move-load" },
    { "id": "c2", "sourceNodeId": "s2-move-load", "targetNodeId": "s2-state-io" },
    { "id": "c3", "sourceNodeId": "s2-state-io", "targetNodeId": "s2-io-wait" },
    { "id": "c4", "sourceNodeId": "s2-io-wait", "targetNodeId": "s2-state-pretest" },
    { "id": "c5", "sourceNodeId": "s2-state-pretest", "targetNodeId": "s2-signal-ready" }
  ],
  "globalVariables": []
}
