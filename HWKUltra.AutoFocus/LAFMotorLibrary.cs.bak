using System;
using System.Net;
using System.Net.Sockets;
using System.Threading;
using System.Text;
using System.Text.RegularExpressions;

namespace WD.AVI.LAFMotorLib
{
    public class LAFMotorLibrary
    {
        const int timeout = 1000;
        static public bool debug = false;
        // response of the last command
        static public String response;

        static private Socket socket = null;
        static private byte[] buffer = new byte[4096];
        static private String received;
        static private Regex rx;
        static private ManualResetEvent waithandle = new ManualResetEvent(false);
        static private ManualResetEvent connected = new ManualResetEvent(false);

        private static LAFMotorLibrary uniqueInstance;
        private static readonly object locker = new object();

        private LAFMotorLibrary()
        {
        }


        public static LAFMotorLibrary GetInstance()
        {
            if (uniqueInstance == null)
            {
                lock (locker)
                {
                    if (uniqueInstance == null)
                    {
                        uniqueInstance = new LAFMotorLibrary();
                    }
                }
            }
            return uniqueInstance;
        }

        public bool Open()
        {
            try
            {
                IPAddress ipAddress = IPAddress.Parse("127.0.0.1");
                // port 7777, means first configurations, if need load other configurations, add port number, 7778 is second configuration
                IPEndPoint remoteEP = new IPEndPoint(ipAddress, 7777);

                response = null;
                received = "";

                socket = new Socket(ipAddress.AddressFamily, SocketType.Stream, ProtocolType.Tcp);

                connected.Reset();
                socket.BeginConnect(remoteEP, ConnectCallback, null);
                if (!connected.WaitOne(timeout))
                    return false;

                rx = new Regex("(.*)\n");

                waithandle.Reset();
                BeginReceive();
                if (waithandle.WaitOne(timeout))
                {
                    Console.WriteLine("connected to '{0}'", response);
                    return true;
                }
                else
                {
                    return false;
                }
            }
            catch (Exception e)
            {
                Console.WriteLine(e.ToString());
                return false;
            }
        }


        public void OpenAF()
        {
            if (!Command("tracklaser 1")) Commandtimeout();
            else Console.WriteLine("openAF, response:{0}", response);
        }

        public void CloseAF()
        {
            if (!Command("tracklaser 0")) Commandtimeout();
            else Console.WriteLine("closeAF, response:{0}", response);

        }

        public void OpenLaser()
        {
            if (!Command("lasergate 1")) Commandtimeout();
            else Console.WriteLine("OpenLaser, response:{0}", response);
        }

        public void CloseLaser()
        {
            if (!Command("lasergate 0")) Commandtimeout();
            else Console.WriteLine("closeAF, response:{0}", response);

        }

        public double Getstfocus()
        {
            double ret = -9999;
            if (!Command("st_focus"))
                Commandtimeout();
            else
            {
                Console.WriteLine("response '{0}'", response);
                double.TryParse(response, out ret);
            }
            return ret;
        }

        public double Getstmpos()
        {
            double ret = -9999;
            if (!Command("st_mpos"))
                Commandtimeout();
            else
            {
                Console.WriteLine("response '{0}'", response);
                double.TryParse(response, out ret);
            }
            return ret;
        }

        public bool Close()
        {
            if (socket != null)
            {
                socket.Shutdown(SocketShutdown.Both);
            }
            return true;
        }

        public void AxisReset()
        {
            if (!Command("movegoto1 0")) Commandtimeout();
            else Console.WriteLine("AxisReset, response:{0}", response);
        }


        private void BeginReceive()
        {
            socket.BeginReceive(buffer, 0, buffer.Length, 0, ReceiveCallback, socket);
        }



        private bool Command(String cstr)
        {
            received = "";
            response = null;

            if (debug)
                Console.WriteLine("send ipc command '{0}'", cstr);

            rx = new Regex(cstr + " ?(.*)\n");

            waithandle.Reset();
            Send(socket, cstr + "\n");
            return waithandle.WaitOne(timeout);
        }

        private void ConnectCallback(IAsyncResult ar)
        {
            try
            {
                socket.EndConnect(ar);

                if (debug)
                    Console.WriteLine("Socket connecting to {0}", socket.RemoteEndPoint.ToString());

                connected.Set();
            }
            catch (Exception e)
            {
                Console.WriteLine(e.ToString());
            }
        }

        private void ReceiveCallback(IAsyncResult ar)
        {
            try
            {
                int bytesRead = socket.EndReceive(ar);
                if (bytesRead > 0)
                {
                    received += Encoding.ASCII.GetString(buffer, 0, bytesRead);
                    Match matches = rx.Match(received);
                    if (matches.Success)
                    {
                        if (matches.Groups.Count > 1)
                        {
                            if (debug)
                                Console.WriteLine("ReceiveCallback match '{1}'", received, matches.Groups[1].Value);
                            response = matches.Groups[1].Value;
                        }
                        waithandle.Set();
                    }
                    BeginReceive();
                }
                else
                {
                }
            }
            catch (System.ArgumentException sae)
            {
                throw sae;
            }
            catch (Exception e)
            {
                Console.WriteLine(e.ToString());
            }
        }

        private void Send(Socket client, String data)
        {
            // Convert the string data to byte data using ASCII encoding.  
            byte[] byteData = Encoding.ASCII.GetBytes(data);

            // Begin sending the data to the remote device.  
            client.BeginSend(byteData, 0, byteData.Length, 0, SendCallback, socket);
        }

        private void SendCallback(IAsyncResult ar)
        {
            try
            {
                int bytesSent = socket.EndSend(ar);
                if (debug)
                    Console.WriteLine("Sent {0} bytes.", bytesSent);
            }
            catch (Exception e)
            {
                Console.WriteLine(e.ToString());
            }
        }

        public void Commandtimeout()
        {
            Console.WriteLine("command timeout");
        }
    }
}

